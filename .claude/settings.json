      "Bash(cmake --build build/ --target vision-detection-service)",
      "Bash(ninja)",
      "Bash(adb shell:*)",
      "Bash(devcontainer up:*)",
      "Bash(bash /Volumes/firmware_cs/vision-services/update.sh --services --adb)",
      "Bash(adb devices:*)"
