[user]
	email = stadnikandriy1@gmail.com
	name = Stadnik Andrii
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	pager = delta
	excludesfile = /Users/astadnik/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	side-by-side = true
	navigate = true    # use n and N to move between diff sections
[merge]
	conflictstyle = diff3
	algorithm = histogram
	renameLimit = 9999
[diff]
	colorMoved = default
	algorithm = histogram
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[rerere]
	enabled = true
[color]
	ui = auto
