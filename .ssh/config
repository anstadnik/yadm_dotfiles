Include ~/.colima/ssh_config

# Force github SSH over port 443 (ssh.github.com). Works on every network and
# avoids the github.com:22 connect timeout on restrictive WiFi, so `git push`
# (and dashboard deploy/ship) never has to probe-then-fall-back. HTTPS/gh CLI
# are unaffected — this only routes git@github.com SSH.
Host github.com
  HostName ssh.github.com
  Port 443
  User git
  IdentityFile ~/.ssh/id_ed25519

Host dell
  HostName 192.168.31.219
  User astadnik
  # Port 39901

Host dell2
  HostName 185.219.77.160
  User astadnik
  # Port 39901

Host rpi
  HostName raspberrypi
  # LAN fallback: raspberrypi.local
  User astadnik

Host digitalocean
  HostName 159.89.0.168
  User root

Host gh_personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519

Host gh_work
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_OMI

Host dod
  # HostName 100.91.60.55
  HostName 10.177.0.192
  User astadnik
  IdentityFile ~/.ssh/id_ed25519_DoD

Host work
  # HostName 10.177.0.108
  HostName 100.74.28.32
  User astadnik
  IdentityFile ~/.ssh/id_ed25519
  # ProxyCommand sh -c 'wakeonlan 30:e3:a4:fd:5a:61 >/dev/null; sleep 8; exec nc %h %p'

Host nixos
