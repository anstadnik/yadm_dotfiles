// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // "theme": "Catppuccin Latte",
  "code_lens": "on",
  "cli_default_open_behavior": "new_window",
  "outline_panel": { "dock": "right" },
  "collaboration_panel": { "dock": "right" },
  "diff_view_style": "split",
  "project_panel": {
    "dock": "right",
    "git_status_indicator": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "github-copilot-cli": { "type": "registry" },
  },
  "icon_theme": "Zed (Default)",
  "document_symbols": "on",
  "tasks": { "prefer_lsp": false },
  "vim": { "toggle_relative_line_numbers": false },
  "auto_signature_help": false,
  "inlay_hints": { "enabled": false },
  "lsp_document_colors": "inlay",
  "which_key": { "enabled": true },
  "git_panel": { "dock": "right", "diff_stats": true, "tree_view": true },
  "remove_trailing_whitespace_on_save": false,
  "format_on_save": "on",
  "context_servers": {},
  "ensure_final_newline_on_save": false,
  "colorize_brackets": true,
  "sticky_scroll": { "enabled": true },
  "show_edit_predictions": true,
  "ssh_connections": [
    {
      "host": "rpi",
      "args": [],
      "projects": [{ "paths": ["/home/astadnik/work/image-localizer"] }],
    },
    {
      "host": "dod",
      "args": [],
      "projects": [
        { "paths": ["/home/astadnik/annotators_report"] },
        { "paths": ["/home/astadnik/hornet-ml-research"] },
        {
          "paths": [
            "/home/astadnik/hornet-ml-research/3rd_party/SiamABC_v2/./",
          ],
        },
      ],
    },
    {
      "host": "work",
      "args": [],
      "projects": [
        { "paths": ["/etc/nixos"] },
        { "paths": ["/home/astadnik/work"] },
        { "paths": ["/home/astadnik/work/avengers/dmt-sample-pipeline/./"] },
        { "paths": ["/home/astadnik/work/convert_rknn"] },
        { "paths": ["/home/astadnik/work/hornet-ml-research"] },
        { "paths": ["/home/astadnik/work/rknn-toolkit"] },
        { "paths": ["/home/astadnik/work/sam_tracking_labeler"] },
        { "paths": ["/home/astadnik/work/vision-rv1126-buildroot"] },
        { "paths": ["/home/astadnik/work/vision-services"] },
      ],
    },
  ],
  "theme": {
    "mode": "system",
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
  },
  "auto_install_extensions": { "Catppuccin": true },
  "agent": {
    "new_thread_location": "local_project",
    "dock": "left",
    "profiles": {},
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-5",
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "zed.dev",
      "model": "claude-opus-4-5",
    },
  },
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_fallbacks": ["Symbols Nerd Font Mono"],
  "telemetry": { "diagnostics": false, "metrics": false },
  "vim_mode": true,
  "show_signature_help_after_edits": true,
  "relative_line_numbers": "enabled",
  "minimap": { "show": "always" },
  "bottom_dock_layout": "full",
  "terminal": {
    "option_as_meta": true,
    "line_height": "standard",
    "dock": "bottom",
  },
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
  },
  "git": { "inline_blame": { "show_commit_summary": false } },
  "languages": {
    "Markdown": { "format_on_save": "off" },
    "LaTeX": { "format_on_save": "off" },
    "YAML": { "format_on_save": "off" },
    "Dockerfile": { "format_on_save": "off" },
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "formatter": {
        "external": {
          "command": "alejandra", // or "nixfmt"
          "arguments": ["--quiet", "--"],
        },
      },
    },
    "C++": {
      "format_on_save": "on",
    },
    "C": {
      "format_on_save": "on",
    },
    "Python": {
      "inlay_hints": {
        "show_value_hints": true,
      },
      // "language_servers": ["basedpyright", "ruff"],
      // "language_servers": ["pyright", "ruff"],
      "language_servers": ["ty", "ruff"],
      // "language_servers": ["zuban", "ruff"],
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
        { "language_server": { "name": "ruff" } },
      ],
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        // "basedpyright.analysis": {
        //   "diagnosticMode": "openFilesOnly"
        // }
      },
    },
    // "pyright": {
    //   "settings": {
    //     "python.analysis": {
    //       "diagnosticMode": "workspace",
    //       // "typeCheckingMode": "strict"
    //     },
    //   },
    // },
    "ty": { "settings": { "diagnosticMode": "workspace" } },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lint": {
            // "extendSelect": ["UP"]
          },
          "format": {
            "skip-magic-trailing-comma": true,
          },
        },
      },
    },
    // ~/.config/zed/settings.json

    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            // "onSave": true,
            // "forwardSearchAfter": true,
            "executable": "tectonic",
            "args": [
              "-X",
              "compile",
              "%f",
              "--untrusted",
              "--synctex",
              "--keep-logs",
              "--keep-intermediates",
            ],
          },
        },
      },
    },
  },
}
