keybind = global:cmd+grave_accent=toggle_quick_terminal
theme = light:Catppuccin Latte,dark:Catppuccin Mocha
background-opacity = 0.9
background-blur-radius = 20
macos-option-as-alt = true
confirm-close-surface = false
mouse-hide-while-typing = true

# cursor integration kept off: tmux re-asserts pane state on every redraw,
# clobbering dynamic bar/block switching.
# sudo is ON: wraps sudo to preserve $TERMINFO — xterm-ghostty terminfo ships in
# Ghostty.app, not the system db, so `sudo nvim` etc. need it in plain-Ghostty shells.
# title is ON: tmux runs set-titles on, so fish-set pane titles (#T) flow through
# to the Ghostty tab title.
# OSC 133 prompt markers (cmd+↑/↓) and OSC 7 (CWD inheritance) are always-on — still work.
shell-integration-features = no-cursor

# custom-shader = ./shaders/cursor_tail.glsl
