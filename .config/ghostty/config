keybind = global:cmd+grave_accent=toggle_quick_terminal
theme = light:Catppuccin Latte,dark:Catppuccin Mocha
background-opacity = 0.7
background-blur-radius = 20
macos-option-as-alt = true
confirm-close-surface = false
mouse-hide-while-typing = true

# All optional shell-integration features off — they don't deliver value through tmux:
#   - cursor: tmux re-asserts pane state on every redraw, clobbering dynamic blink.
#   - sudo: redundant with pam_tid.so (Touch ID succeeds before askpass triggers).
#   - title: tmux drives its own window-status from pane_current_command, not OSC titles.
# OSC 133 prompt markers (cmd+↑/↓) and OSC 7 (CWD inheritance) are always-on — still work.
shell-integration-features = no-cursor,no-sudo,no-title

