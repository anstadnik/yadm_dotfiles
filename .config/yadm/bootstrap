#!/usr/bin/env bash
# macOS bootstrap. Linux is managed by NixOS + home-manager; dotfiles by yadm.
set -e

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "bootstrap is macOS-only — Linux is managed by NixOS + home-manager." >&2
    exit 0
fi

# Homebrew + everything declared in the Brewfile
if ! command -v brew >/dev/null 2>&1; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv)"

# Homebrew >= 6 refuses third-party taps until trusted
grep -E '^tap ' "$HOME/.config/yadm/Brewfile" | cut -d'"' -f2 | while read -r t; do
    brew tap "$t"
    brew trust "$t"
done

brew bundle --file "$HOME/.config/yadm/Brewfile"

# Default shell -> fish
fish_path="$(command -v fish)"
grep -qxF "$fish_path" /etc/shells || echo "$fish_path" | sudo tee -a /etc/shells
[ "$SHELL" = "$fish_path" ] || sudo chsh -s "$fish_path" "$USER"

# SSH key (only if missing)
[ -f "$HOME/.ssh/id_ed25519" ] || ssh-keygen -t ed25519 -q -N "" -f "$HOME/.ssh/id_ed25519"

# fish plugins (fisher installed via brew; plugin list in ~/.config/fish/fish_plugins)
fish -c "fisher update"
